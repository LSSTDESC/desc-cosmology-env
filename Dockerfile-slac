# =============================================================================
# DESC Cosmology Environment Container — S3DF (SLAC) Edition
# Runtime: Apptainer/Singularity on S3DF milano partition
#
# MPI Strategy:
#   S3DF does NOT inject MPI at runtime (unlike NERSC Shifter/podman-hpc).
#   The container carries its own full OpenMPI installation via apt-get.
#   Ubuntu 22.04 ships OpenMPI 4.1.2, matching S3DF's 4.1.1 (same minor
#   version, fully ABI and wire-protocol compatible).
#   mpi4py is pip-installed from source against the system OpenMPI headers.
#   At runtime, Apptainer uses the container's mpirun to launch MPI jobs.
#
# Build:
#   docker build -f Dockerfile.s3df -t lsstdesc/desc-cosmology-s3df:latest .
#
# Push to registry so Apptainer can pull it on S3DF:
#   docker push lsstdesc/desc-cosmology-s3df:latest
#
# On S3DF — convert to .sif (do this once on an interactive node):
#   apptainer pull desc-cosmology-s3df.sif \
#     docker://lsstdesc/desc-cosmology-s3df:latest
#
# Interactive shell on S3DF:
#   apptainer shell \
#     -B /sdf,/fs,/sdf/scratch,/lscratch \
#     /path/to/desc-cosmology-s3df.sif
#
# MPI batch job (sbatch script):
#   #!/bin/bash
#   #SBATCH --partition=milano
#   #SBATCH --nodes=2
#   #SBATCH --ntasks-per-node=4
#   mpirun -n 8 apptainer exec \
#     -B /sdf,/fs,/sdf/scratch,/lscratch \
#     /path/to/desc-cosmology-s3df.sif \
#     /opt/desc/bin/python your_script.py
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Build the conda environment
# -----------------------------------------------------------------------------
FROM continuumio/miniconda3:latest AS conda

ARG DESC_PYTHON_DIR=/opt/desc

ENV PYTHONDONTWRITEBYTECODE=1

RUN conda install -y -c conda-forge condax && \
    condax install -c conda-forge conda-lock

COPY conda/lock/auto/desc-cosmology-lock-slac-main-2026-06-25.yml /locks/conda-linux-64.lock

RUN mkdir -p ${DESC_PYTHON_DIR} && \
    ~/.local/bin/conda-lock install --mamba -p ${DESC_PYTHON_DIR} /locks/conda-linux-64.lock && \
    find ${DESC_PYTHON_DIR} -name "*.pyc" -delete && \
    find ${DESC_PYTHON_DIR} -name "*.pyo" -delete && \
    (find ${DESC_PYTHON_DIR} -name "doc" -type d | xargs rm -rf) || true 

# -----------------------------------------------------------------------------
# Stage 2: Runtime image
# Ubuntu 22.04 ships OpenMPI 4.1.2 which is ABI-compatible with S3DF's 4.1.1
# -----------------------------------------------------------------------------
FROM ubuntu:22.04

LABEL maintainer="Heather Kelly <heather@slac.stanford.edu>"
LABEL org.opencontainers.image.source="https://github.com/LSSTDESC/desc-cosmology-env"
LABEL org.opencontainers.image.description="DESC Cosmology environment for S3DF/SLAC (OpenMPI, Apptainer)"

ARG DESC_PYTHON_DIR=/opt/desc
ARG LSST_UID=1001
ARG LSST_GID=1001
# CosmoSIS standard library branch to build
ARG COSMOSIS_SL_BRANCH=main
ARG MPI4PY_VERSION=4.0.3

# Create lsst user/group.
# UID/GID 1001 avoids Ubuntu 22.04's pre-allocated GID 1000.
RUN groupadd -g ${LSST_GID} -r lsst && \
    useradd -u ${LSST_UID} --no-log-init -m -r -g lsst lsst && \
    usermod --shell /bin/bash lsst && \
    mkdir -p ${DESC_PYTHON_DIR} && \
    chown lsst:lsst ${DESC_PYTHON_DIR}

# Install runtime dependencies and OpenMPI.
# libopenmpi-dev: OpenMPI headers + libmpi.so needed for pip mpi4py build
# openmpi-bin: provides mpirun for launching MPI jobs
# libgomp1: OpenMP runtime (needed by cosmology codes e.g. CosmoSIS samplers)
# procps: provides ps, used by some MPI and job tools
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
        build-essential \
        gfortran \
        wget \
        curl \
        git \
        patch \
        ca-certificates \
        libgomp1 \
        procps \
        libopenmpi-dev \
        openmpi-bin && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt

# Verify OpenMPI version matches S3DF (expected: 4.1.x)
RUN mpirun --version

# Copy the conda environment from build stage
COPY --from=conda --chown=lsst:lsst ${DESC_PYTHON_DIR} ${DESC_PYTHON_DIR}
COPY --from=conda /locks /locks

# Install mpi4py via pip, compiled from source against the system OpenMPI.
# --no-binary forces source compilation so it links against the apt-installed
# libmpi.so rather than using a pre-built wheel linked against a different MPI.
#RUN ${DESC_PYTHON_DIR}/bin/pip install \
#        --no-cache-dir \
#        --no-binary mpi4py \
#        mpi4py==${MPI4PY_VERSION} && \
#    echo "=== mpi4py linkage ===" && \
#    ldd ${DESC_PYTHON_DIR}/lib/python*/site-packages/mpi4py/MPI*.so | grep -i mpi && \
#    echo "=== mpi4py version ===" && \
#    ${DESC_PYTHON_DIR}/bin/python -c "import mpi4py; print(mpi4py.__version__)"

# -----------------------------------------------------------------------------
# Build CosmoSIS standard library
#
# Replicates the manual setup steps:
#   conda env config vars set CSL_DIR=${CONDA_PREFIX}/cosmosis-standard-library
#   cd ${CONDA_PREFIX}
#   config_cosmosis
#   cosmosis-build-standard-library main
#
# Notes:
#   - config_cosmosis is a shell function defined in cosmosis's activate script;
#     we source it explicitly here since we're not in an interactive conda env
#   - CSL_DIR is set to ${DESC_PYTHON_DIR}/cosmosis-standard-library, matching
#     what conda env config vars would set at runtime
#   - cosmosis-build-standard-library clones from GitHub and builds Fortran/C
#     modules, so build-essential and gfortran must be installed above
#   - The build runs as root so it can write into ${DESC_PYTHON_DIR};
#     ownership is fixed afterward
# -----------------------------------------------------------------------------
ENV CSL_DIR=${DESC_PYTHON_DIR}/cosmosis-standard-library
ENV COSMOSIS_SRC_DIR=${DESC_PYTHON_DIR}

RUN bash -c "\
    source ${DESC_PYTHON_DIR}/bin/activate && \
    source ${DESC_PYTHON_DIR}/bin/cosmosis-configure && \
    cd ${DESC_PYTHON_DIR} && \
    cosmosis-build-standard-library ${COSMOSIS_SL_BRANCH}" && \
    echo "=== CosmoSIS standard library built ===" && \
    ls ${DESC_PYTHON_DIR}/cosmosis-standard-library 

# Need to fix this
#    python_ver_major=$(python -c 'import sys; print(sys.version_info.major)') && \
#    python_ver_minor=$(python -c 'import sys; print(sys.version_info.minor)') && \
#    export DESC_VER_LIBPYTHON="$python_ver_major.$python_ver_minor"

# Add an entrypoint script
COPY slac/s3df-entrypoint.sh /opt/desc/bin/s3df-entrypoint.sh
RUN chmod +x /opt/desc/bin/s3df-entrypoint.sh

# Fix ownership after pip install as root
RUN chown -R lsst:lsst ${DESC_PYTHON_DIR}

# Switch to non-root user
USER lsst

# Environment
ENV PYTHONDONTWRITEBYTECODE=1
# Prevents HDF5 locking issues on Lustre (/sdf/scratch, /fs/ddn/sdf)
ENV HDF5_USE_FILE_LOCKING=FALSE
# CosmoSIS: avoid subprocess spawning in samplers
ENV COSMOSIS_NO_SUBPROCESS=1
# Prevents mpi4py MPI_Mprobe hang with some OpenMPI configurations
ENV MPI4PY_RC_RECV_MPROBE=0
ENV PYTHONSTARTUP=''
ENV PATH="${DESC_PYTHON_DIR}/bin:/usr/lib64/openmpi/bin:${PATH}"
# Ubuntu puts OpenMPI libs here; needed so libmpi.so is found at runtime
# inside Apptainer which doesn't always propagate the apt ldconfig cache
ENV LD_LIBRARY_PATH="/usr/lib/x86_64-linux-gnu/openmpi/lib:${LD_LIBRARY_PATH}"

# Shell startup
## HMKneedto fix path for firecrown_dir
RUN echo "source ${DESC_PYTHON_DIR}/bin/activate" >> ~/.bashrc && \
    echo "source cosmosis-configure 2>/dev/null || true" >> ~/.bashrc && \
    echo "export FIRECROWN_DIR=${DESC_PYTHON_DIR}/lib/3.11/site-packages" >> ~/.bashrc && \
    echo "export COSMOSIS_NO_SUBPROCESS=1" >> ~/.bashrc && \
    echo "export MPI4PY_RC_RECV_MPROBE=0" >> ~/.bashrc && \
    echo "export HDF5_USE_FILE_LOCKING=FALSE" >> ~/.bashrc

SHELL ["/bin/bash", "--login", "-c"]

# Build-time sanity checks
RUN python -c "import firecrown; print('firecrown OK')" && \
    python -c "import mpi4py; print('mpi4py OK:', mpi4py.__version__)" && \
    mpirun -n 2 python -m mpi4py.bench helloworld

WORKDIR /home/lsst

# No ENTRYPOINT — Apptainer works best without one;
# allows both 'apptainer shell' and 'apptainer exec ... python script.py'
